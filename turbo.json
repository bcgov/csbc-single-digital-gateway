{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "db:migrate": {
      "cache": false,
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "persistent": true
    },
    "api#dev": {
      "cache": false,
      "dependsOn": [
        "^build",
        "db:migrate"
      ],
      "persistent": true
    },
    "lint": {},
    "test:unit": {},
    "test:int": {},
    "test:cov": {}
  }
}