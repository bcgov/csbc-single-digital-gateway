{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "db:migrate": {
      "cache": false,
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "persistent": true
    },
    "api#dev": {
      "cache": false,
      "dependsOn": [
        "^build",
        "db:migrate"
      ],
      "persistent": true
    },
    "lint": {},
    "test:unit": {
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_REDIRECT_URI",
        "OIDC_POST_LOGOUT_REDIRECT_URI",
        "OIDC_CLIENT_AUTH_METHOD",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_SECRET",
        "AUTH_OIDC_REDIRECT_URI",
        "AUTH_OIDC_POST_LOGOUT_REDIRECT_URI",
        "AUTH_OIDC_CLIENT_AUTH_METHOD",
        "SESSION_SECRET",
        "FRONTEND_URL",
        "ADMIN_FRONTEND_URL"
      ]
    },
    "test:int": {
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_REDIRECT_URI",
        "OIDC_POST_LOGOUT_REDIRECT_URI",
        "OIDC_CLIENT_AUTH_METHOD",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_SECRET",
        "AUTH_OIDC_REDIRECT_URI",
        "AUTH_OIDC_POST_LOGOUT_REDIRECT_URI",
        "AUTH_OIDC_CLIENT_AUTH_METHOD",
        "SESSION_SECRET",
        "FRONTEND_URL",
        "ADMIN_FRONTEND_URL"
      ]
    },
    "test:cov:api": {
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_REDIRECT_URI",
        "OIDC_POST_LOGOUT_REDIRECT_URI",
        "OIDC_CLIENT_AUTH_METHOD",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_SECRET",
        "AUTH_OIDC_REDIRECT_URI",
        "AUTH_OIDC_POST_LOGOUT_REDIRECT_URI",
        "AUTH_OIDC_CLIENT_AUTH_METHOD",
        "SESSION_SECRET",
        "FRONTEND_URL",
        "ADMIN_FRONTEND_URL"
      ]
    },
    "test:vscode": {
      "passThroughEnv": [
        "DB_NAME",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASS",
        "DB_SSL",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_REDIRECT_URI",
        "OIDC_POST_LOGOUT_REDIRECT_URI",
        "OIDC_CLIENT_AUTH_METHOD",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_SECRET",
        "AUTH_OIDC_REDIRECT_URI",
        "AUTH_OIDC_POST_LOGOUT_REDIRECT_URI",
        "AUTH_OIDC_CLIENT_AUTH_METHOD",
        "SESSION_SECRET",
        "FRONTEND_URL",
        "ADMIN_FRONTEND_URL"
      ]
    },
    "test:component": {},
    "test:cov:web": {
      "passThroughEnv": [
        "APP_PORT"
      ]
    },
    "test:open": {
      "passThroughEnv": [
        "WEB_APP_URL",
        "CYPRESS_TEST_USERNAME",
        "CYPRESS_TEST_PASSWORD"
      ]
    },
    "test:e2e": {
      "passThroughEnv": [
        "WEB_APP_URL",
        "CYPRESS_TEST_USERNAME",
        "CYPRESS_TEST_PASSWORD"
      ]
    },
    "test:e2e:report": {
      "passThroughEnv": [
        "WEB_APP_URL",
        "CYPRESS_TEST_USERNAME",
        "CYPRESS_TEST_PASSWORD"
      ]
    },
    "test:login": {
      "passThroughEnv": [
        "WEB_APP_URL",
        "CYPRESS_TEST_USERNAME",
        "CYPRESS_TEST_PASSWORD"
      ]
    },
    "test:load:api": {},
    "test:load:web": {},
    "test:smoke:api": {},
    "test:smoke:web": {},
    "test:stress:api": {},
    "test:stress:web": {},
    "cookies:delete": {}
  }
}