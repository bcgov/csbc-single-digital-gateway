{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Unit Test - Current File",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "npm run test -- ${fileBasename}",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "API Unit Test - All Files",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "npm run test",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "API E2E Test - Current File",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "npm run test:e2e -- ${fileBasename}",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "API E2E Test - All Files",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "npm run test:e2e",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web Component Test - Current File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/cypress/bin/cypress",
      "args": ["run", "--component", "--spec", "${file}"],
      "env": {
        "allowCypressEnv": "true",
        "NODE_ENV": "local"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web Component Test - All Files",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/cypress/bin/cypress",
      "args": ["run", "--component"],
      "env": {
        "allowCypressEnv": "true",
        "NODE_ENV": "local"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web E2E Test - Current File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/cypress/bin/cypress",
      "args": ["run", "--e2e", "--spec", "${file}"],
      "env": {
        "allowCypressEnv": "true",
        "NODE_ENV": "local"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Web E2E Test - All Files",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/cypress/bin/cypress",
      "args": ["run", "--e2e"],
      "env": {
        "allowCypressEnv": "true",
        "NODE_ENV": "local"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
