    "test:admin:web-stress-test": "dotenv -e .env k6 run admin/web-stress-test.ts",
    "test:client:api-load-test": "dotenv -e .env k6 run client/api-load-test.ts",
    "test:client:api-smoke-test": "dotenv -e .env k6 run client/api-smoke-test.ts",
    "test:client:api-stress-test": "dotenv -e .env k6 run client/api-stress-test.ts",
    "test:client:web-load-test": "dotenv -e .env k6 run client/web-load-test.ts",
