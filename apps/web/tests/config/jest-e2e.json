{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts",
    "tsx"
  ],
  "rootDir": "../../",
  "testRegex": "\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(ts|tsx)$": "babel-jest"
  },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "globals": {
    "APP_PORT": "5173"
  },
  "moduleNameMapper": {
    "\\.(gif|ttf|eot|svg|png)$": "<rootDir>/tests/config/fileMock.js",
    "\\.(css|less|sass|scss)$": "identity-obj-proxy",
    "^tests/(.*)$": "<rootDir>/tests/$1",
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}