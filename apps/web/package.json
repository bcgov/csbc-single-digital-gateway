  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "cy:component": "npm run report:delete && cypress run --component",
    "cy:component:report": "npm run report:delete && cross-env REPORT=true cypress run --component",
    "cy:e2e": "npm run report:delete && cypress run --e2e",
    "cy:e2e:report": "npm run report:delete && cross-env REPORT=true cypress run --e2e",
    "cy:open": "npm run report:delete && cypress open",
    "report:delete": "rm -rf cypress/reports/* || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
