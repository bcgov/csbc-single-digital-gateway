    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/eslint-plugin-router": "^1.141.0",
    "@tanstack/router-plugin": "^1.145.11",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "cypress": "^15.12.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
