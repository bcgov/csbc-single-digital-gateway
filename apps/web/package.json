{
  "name": "web",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test:component": "jest",
    "test:watch": "jest --watch",
    "test:cov:web": "jest --coverage > ./tests/coverage/coverage.txt && echo \"Coverage Report\" && cat ./tests/coverage/coverage.txt"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dr.pogodin/react-helmet": "^3.0.5",
    "@jsonforms/core": "^3.7.0",
    "@jsonforms/react": "^3.7.0",
    "@monaco-editor/react": "^4.7.0",
    "@repo/jsonforms": "*",
    "@repo/ui": "^0.0.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router": "^1.145.11",
    "@tanstack/react-router-devtools": "^1.145.11",
    "axios": "^1.13.2",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/eslint-plugin-router": "^1.141.0",
    "@tanstack/router-plugin": "^1.145.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-jest": "^30.3.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "babel-preset-vite": "^1.1.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.1",
    "vite-plugin-runtime-env": "^1.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.tsx?$",
    "transform": {
      "^.+\\.(ts|tsx)$": "babel-jest"
    },
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/config/setupTests.ts"
    ],
    "moduleNameMapper": {
      "\\.(gif|ttf|eot|svg|png)$": "<rootDir>/tests/config/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy",
      "^tests/(.*)$": "<rootDir>/tests/$1",
      "^src/(.*)$": "<rootDir>/src/$1",
      "^(.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.tsx"
    ],
    "coverageDirectory": "./tests/coverage",
    "coverageReporters": [
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    },
    "coveragePathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/node_modules/",
      "<rootDir>/tests/utils/",
      "<rootDir>/.*\\.d\\.ts$",
      "<rootDir>/src/main.tsx",
      "<rootDir>/src/features/auth/auth.context.tsx"
    ]
  }
}