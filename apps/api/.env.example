# Server
NODE_ENV=development
PORT=4000
HEALTH_PORT=9000

# Database
DB_NAME=sdg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your-db-password
DB_SSL=false

# Identity Provider (OIDC)
OIDC_ISSUER=http://localhost:8080/realms/your-realm
OIDC_CLIENT_ID=sdg-api
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:4000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Session
SESSION_SECRET=your-session-secret

# Frontend
FRONTEND_URL=http://localhost:5173

# Consent Manager (optional)
CONSENT_MANAGER_API_URL=http://localhost:3001
