# Server
NODE_ENV=development
PORT=4000
HEALTH_PORT=9000

# Database
DB_NAME=sdg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your-db-password
DB_SSL=false

# Identity Provider — BCSC (citizen-facing)
OIDC_ISSUER=http://localhost:8080/realms/bcsc
OIDC_CLIENT_ID=sdg-api
OIDC_CLIENT_SECRET=your-bcsc-client-secret
OIDC_REDIRECT_URI=http://localhost:4000/auth/bcsc/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
OIDC_CLIENT_AUTH_METHOD=client_secret_post

# Identity Provider — IDIR (internal staff)
AUTH_OIDC_ISSUER=http://localhost:8080/realms/idir
AUTH_OIDC_CLIENT_ID=sdg-api-idir
AUTH_OIDC_CLIENT_SECRET=your-idir-client-secret
AUTH_OIDC_REDIRECT_URI=http://localhost:4000/auth/idir/callback
AUTH_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
AUTH_OIDC_CLIENT_AUTH_METHOD=client_secret_post

# Session
SESSION_SECRET=your-session-secret

# Frontend
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5173/admin

# Consent Manager (optional)
CONSENT_MANAGER_API_URL=http://localhost:3001

# Public Bodies API (optional)
PUBLIC_BODIES_API_URL=https://dir.api.gov.bc.ca/api/public-bodies

# Workflow API (optional)
WORKFLOW_API_URL=http://localhost:5678
