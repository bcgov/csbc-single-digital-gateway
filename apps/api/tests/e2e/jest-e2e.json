{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "../../",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/common/(.*)$": "<rootDir>/src/common/$1",
    "^src/database/(.*)$": "<rootDir>/src/database/$1",
    "^src/modules/(.*)$": "<rootDir>/src/modules/$1"
  }
}