{
  "name": "root",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=api",
    "build:web": "turbo run build --filter=web",
    "build:@repo/db": "turbo run build --filter=@repo/db",
    "build:@repo/ui": "turbo run build --filter=@repo/ui",
    "db:migrate": "turbo run db:migrate",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test:unit": "turbo run test:unit",
    "test:int": "turbo run test:int",
    "test:cov:api": "turbo run test:cov:api",
    "test:vscode": "turbo run test:vscode",
    "test:component": "turbo run test:component",
    "test:cov:web": "turbo run test:cov:web",
    "test:open": "turbo run test:open",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:report": "turbo run test:e2e:report",
    "test:login": "turbo run test:login",
    "test:load:api": "turbo run test:load:api",
    "test:load:web": "turbo run test:load:web",
    "test:smoke:api": "turbo run test:smoke:api",
    "test:smoke:web": "turbo run test:smoke:web",
    "test:stress:api": "turbo run test:stress:api",
    "test:stress:web": "turbo run test:stress:web",
    "cookies:delete": "turbo run cookies:delete"
  },
  "devDependencies": {
    "turbo": "^2.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "testings/*"
  ]
}